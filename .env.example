# Express listening port
PORT=3000

# Zoom Webhook Secret Token (from Marketplace app > Feature > Event Subscriptions)
ZOOM_WEBHOOK_SECRET_TOKEN=your_webhook_secret_token_here

# Server-to-Server OAuth credentials (from Marketplace app > App Credentials)
ZOOM_ACCOUNT_ID=your_account_id_here
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
